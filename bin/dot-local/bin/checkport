#!/bin/bash

if [ -z "$1" ]; then
  echo "Usage: $0 <port_number>"
  exit 1
fi

port="$1"

echo "Checking which process is using port $port..."

process_id=$(lsof -i :"$port" -P -n -t 2>/dev/null)

if [ -n "$process_id" ]; then
  echo "PID: $process_id"
  ps -p "$process_id" -o pid=,user=,command=
  exit 0
fi

ss_output=$(ss -lptn "sport = :$port" 2>/dev/null | tail -n +2)

if [ -n "$ss_output" ]; then
  echo "$ss_output" | while read -r line; do
    pid=$(echo "$line" | grep -oP 'pid=\K[0-9]+')
    if [ -n "$pid" ]; then
      echo "PID: $pid"
      ps -p "$pid" -o pid=,user=,command= 2>/dev/null || echo "  (could not read process details — try with sudo)"
    else
      echo "$line"
      echo "(process info hidden — try with sudo)"
    fi
  done
  exit 0
fi

echo "No process found listening on port $port."
